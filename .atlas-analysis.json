  "keyFeatures": [
    "Accessible - WAI-ARIA compliant components with keyboard navigation and screen reader support",
    "Unstyled - Zero default styles, fully customizable with any styling solution",
    "Composable - Granular component APIs with 1-to-1 DOM mapping for maximum flexibility",
    "Controlled & Uncontrolled - Support for both controlled and uncontrolled component states",
    "Type-safe - Written in TypeScript with complete type definitions",
    "Incremental Adoption - Use individual components or the entire library",
    "SSR Compatible - Works with Next.js, Remix, and other React frameworks",
    "Cross-browser - Tested across modern browsers and assistive technologies"
  ],
